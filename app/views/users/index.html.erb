<% page_data(title: "Users (#{govuk_number(@pagy.count)})") %>

<%= govuk_button_link_to("Add user", new_user_path) %>

<%= govuk_table do |table|
      table.with_head do |head|
        head.with_row do |row|
          row.with_cell(text: "Name")
          row.with_cell(text: "Email address")
          row.with_cell(text: "Status")
        end
      end
      table.with_body do |body|
        @records.each do |user|
          body.with_row do |row|
            row.with_cell(text: govuk_link_to(user.name, href: user_path(user)))
            row.with_cell(text: user.email)
            row.with_cell(text: tag.div(status_tags(user), class: "app-tag-list"))
          end
        end
      end
    end %>

<%= render PaginationDisplay::View.new(pagy: @pagy) %>
